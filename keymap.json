[
  {
    "bindings": {
      "ctrl-w": "pane::CloseActiveItem",
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "space O": "projects::OpenRecent",
    },
  },
  {
    "context": "(!Terminal && Editor) && vim_mode == normal",
    "bindings": {
      "s s": "pane::SplitHorizontal",
      "s v": "pane::SplitVertical",
      "s h": "workspace::ActivatePaneLeft",
      "s l": "workspace::ActivatePaneRight",
      "s k": "workspace::ActivatePaneUp",
      "s j": "workspace::ActivatePaneDown",
      "s shift-l": "editor::MoveRight",
      "alt-l": "workspace::ToggleRightDock",
      "space x": "pane::CloseActiveItem",
      "space e": "project_panel::ToggleFocus",
      "space q": "pane::CloseActiveItem",
      "space c o": "pane::CloseOtherItems",
      "space r e": "editor::Rename",
      "space w w": "workspace::Save",
      "space w a": "workspace::SaveAll",
      "space f f": "file_finder::Toggle",
      "space f w": "workspace::NewSearch",
      "space f d": "diagnostics::Deploy",
      "space f j": "editor::GoToDiagnostic",
      "space f k": "editor::GoToPreviousDiagnostic",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "left": ["editor::MoveUpByLines", { "lines": 10 }],
      "right": ["editor::MoveDownByLines", { "lines": 10 }],
      "z j": ["workspace::SendKeystrokes", "z t"],
      "z k": ["workspace::SendKeystrokes", "z b"],
      "g a": "editor::ToggleCodeActions",
      "+": ["workspace::SendKeystrokes", "ctrl-a"],
      "-": ["workspace::SendKeystrokes", "ctrl-x"],
      "ctrl-j": ["workspace::SendKeystrokes", "j _"],
      "ctrl-k": ["workspace::SendKeystrokes", "k _"],
      "space space": ["workspace::SendKeystrokes", "ctrl-^"],
      "space =": "editor::Format",
      "g c c": "editor::ToggleComments",
      "space a": "editor::ToggleComments",
      "space c h": "pane::CloseItemsToTheLeft",
      "space c l": "pane::CloseItemsToTheRight",
      "space <": "pane::SwapItemLeft",
      "space >": "pane::SwapItemRight",
      "f8": "editor::GoToDiagnostic",
      "shift-f8": "editor::GoToPreviousDiagnostic",
      "shift-k": "editor::Hover",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-|": "pane::SplitRight",
      "ctrl--": "pane::SplitDown",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl space": "editor::ShowCompletions",
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
      "k k": "vim::NormalBefore",
      "k j": "vim::NormalBefore",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "x": "project_panel::Cut",
      "p": "project_panel::Paste",
      "d": "project_panel::Trash",
      "y": "project_panel::Copy",
      "enter": "editor::OpenSelectedFilename",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "right": ["workspace::SendKeystrokes", "1 0 j"],
      "left": ["workspace::SendKeystrokes", "1 0 k"],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-l": "workspace::ToggleBottomDock",
      "alt-l": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-l": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "(Dock && !Terminal)",
    "bindings": {
      "s h": "workspace::ActivatePaneLeft",
      "s l": "workspace::ActivatePaneRight",
      "s k": "workspace::ActivatePaneUp",
      "s j": "workspace::ActivatePaneDown",
      "space x": "workspace::CloseActiveDock",
      "alt-l": "workspace::ToggleRightDock",
      "ctrl-l": "workspace::ToggleBottomDock",
    },
  },
]
