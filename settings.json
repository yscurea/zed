{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "cli_default_open_behavior": "existing_window",
  "hide_mouse": "on_typing",
  "project_panel": {
    "hide_gitignore": false,
    "hide_hidden": false,
    "dock": "left",
    "hide_root": true,
    "show_diagnostics": "all",
  },
  "file_scan_exclusions": [],
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "terminal": {
    "dock": "right",
    "shell": {
      "program": "nu.exe",
    },
  },
  "debugger": {
    "dock": "right",
  },
  "agent": {
    "dock": "bottom",
    "terminal_init_command": "claude",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "vim_mode": true,
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "ui_font_family": "RobotoMono Nerd Font Mono",
  "buffer_font_family": "RobotoMono Nerd Font Mono",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Dark Soft",
  },
}
